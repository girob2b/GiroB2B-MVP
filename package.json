{
  "name": "girob2b",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "pnpm --filter @girob2b/web dev",
    "dev:web": "pnpm --filter @girob2b/web dev",
    "dev:scraper": "pnpm --filter @girob2b/scraper dev",
    "build": "pnpm --filter @girob2b/web build",
    "build:web": "pnpm --filter @girob2b/web build",
    "lint": "pnpm --filter @girob2b/web lint",
    "typecheck": "pnpm --filter @girob2b/web exec tsc --noEmit"
  },
  "devDependencies": {
    "concurrently": "9.2.1"
  }
}
