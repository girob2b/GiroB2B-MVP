# ── Servidor ────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
LOG_LEVEL=info

# ── Redis (BullMQ) ──────────────────────────────────────────────────
REDIS_URL=redis://girob2b-redis:6379

# ── Supabase (service role — acesso ao schema scraper) ─────────────
SUPABASE_URL=https://gwsfovtcsggbdrerynbf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── SearXNG (meta-search self-hosted) ───────────────────────────────
SEARXNG_URL=http://girob2b-searxng:8080

# ── BrasilAPI (sem auth) ────────────────────────────────────────────
BRASILAPI_URL=https://brasilapi.com.br/api

# ── Extração por LLM ────────────────────────────────────────────────
# V1: Gemini Flash free tier (1500 req/dia) — gerar em https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Rate limits / TTLs ──────────────────────────────────────────────
MAX_JOBS_PER_USER_PER_MIN=5
CACHE_TTL_HOURS=24
CONTENT_REFRESH_DAYS=30
SCRAPE_TIMEOUT_MS=15000
