# pnpm config — monorepo girob2b

# Lockfile compartilhado na raiz (default em pnpm — explicitando).
shared-workspace-lockfile=true

# Permite peer deps faltando sem falhar — útil em monorepos com versionamento
# por workspace; revisar caso a caso quando warn aparecer.
strict-peer-dependencies=false

# Hoist apenas o necessário pra ferramentas que esperam node_modules tradicional
# (Next.js, Vite, ESLint resolvem deps via algoritmo próprio sem precisar disso,
# mas alguns plugins legados ainda dependem).
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*

# Auto-install peer deps (pnpm 8+) — reduz fricção em adicionar pacotes novos.
auto-install-peers=true
